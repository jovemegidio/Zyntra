        // Carregar produtos do servidor - USANDO API DE ESTOQUE UNIFICADO (PRODUTOS)
        async function carregarProdutos(silent = false) {
            const btn = document.getElementById('btn-refresh');
            const loading = document.getElementById('loading-overlay');
            
            btn.classList.add('loading');
            if (!silent) loading.style.display = 'flex';

            try {
                // API DE ESTOQUE - Retorna PRODUTOS com estoque (não materiais/matéria-prima)
                const response = await fetch('/api/estoque', { credentials: 'include' });
                
                if (!response.ok) throw new Error('Erro ao carregar produtos');
                
                const body = await response.json();
                
                // Produtos da tabela produtos
                const produtos = body.produtos || [];
                const stats = body.estatisticas || {};
                
                if (produtos.length === 0) {
                    // Mostrar mensagem informativa se não há produtos disponíveis
                    todosProdutos = [];
                    atualizarEstatisticas({});
                    filtrarProdutos();
                    document.getElementById('last-update').textContent = new Date().toLocaleTimeString('pt-BR');
                    return;
                }
                
                todosProdutos = produtos.map(p => {
                    // Dados já vêm formatados da nova API
                    const codigo = p.codigo || p.id || '';
                    const descricao = p.nome || p.descricao || '';
                    const sku = p.sku || '-';
                    const categoria = p.categoria || detectarCategoria(descricao);
                    const estoque = Number(p.estoque_atual || 0);
                    const estoqueMinimo = Number(p.estoque_minimo || 10);
                    const preco = Number(p.preco || 0);
                    const gtin = p.gtin || '';
                    const unidade = p.unidade_medida || 'M';
                    
                    return {
                        id: p.id,
                        codigo: codigo,
                        nome: descricao,
                        descricao: descricao,
                        sku: sku,
                        categoria: categoria,
                        estoque: estoque,
                        estoque_minimo: estoqueMinimo,
                        preco: preco,
                        gtin: gtin,
                        unidade: unidade,
                        ultima_movimentacao: p.ultima_movimentacao,
                        total_movimentacoes: p.total_movimentacoes,
                        // Dados originais para referência
                        _raw: p
                    };
                });

                // Atualiza estatísticas da API
                atualizarEstatisticas(stats);
                
                // Filtra e renderiza
                filtrarProdutos();
                
                // Atualiza timestamp
                document.getElementById('last-update').textContent = new Date().toLocaleTimeString('pt-BR');

            } catch (error) {
                console.error('Erro:', error);
                if (!silent) mostrarErro('Erro ao carregar produtos. Tente novamente.');
            } finally {
                btn.classList.remove('loading');
                loading.style.display = 'none';
            }
        }

        // Detectar categoria pelo nome do produto (DUPLEX, TRIPLEX, etc)
        function detectarCategoria(nome) {
            if (!nome) return 'OUTROS';
            nome = nome.toUpperCase();
            // Detectar pela formAção do cabo (2X, 3X, 4X, etc) - sem \b no final para pegar 3X2,5
            if (nome.includes('DUPLEX') || nome.includes('DUN') || nome.includes('DUI') || /\b2\s*X/.test(nome)) return 'DUPLEX';
            if (nome.includes('TRIPLEX') || nome.includes('TRI') || /\b3\s*X/.test(nome)) return 'TRIPLEX';
            if (nome.includes('QUADRUPLEX') || nome.includes('QDR') || nome.includes('QDN') || /\b4\s*X/.test(nome)) return 'QUADRUPLEX';
            if (nome.includes('QUINTUPLEX') || nome.includes('QUI') || /\b5\s*X/.test(nome)) return 'QUINTUPLEX';
            if (nome.includes('SEXTUPLEX') || nome.includes('SEX') || /\b6\s*X/.test(nome)) return 'SEXTUPLEX';
            if (nome.includes('MULTIPLEX') || nome.includes('MULTI') || /\b[7-9]\s*X/.test(nome) || /\b\d{2,}\s*X/.test(nome)) return 'MULTIPLEX';
            if (nome.includes('UNIPOLAR') || /\b1\s*X/.test(nome)) return 'UNIPOLAR';
            return 'OUTROS';
        }

        // Obter status do estoque - MESMA LÓGICA DO PCP
        function getStatusEstoque(estoque, estoqueMinimo = 10) {
            if (estoque <= 0) return { status: 'critico', label: 'Crítico', class: 'danger' };
            if (estoque <= estoqueMinimo) return { status: 'baixo', label: 'Baixo', class: 'warning' };
            return { status: 'normal', label: 'Normal', class: 'success' };
        }

        // Atualizar estatísticas - USANDO DADOS DA API /api/estoque
        function atualizarEstatisticas(apiStats = {}) {
            const total = apiStats.total || todosProdutos.length;
            
            // Calcular estatísticas se não vieram da API
            let estoqueNormal = 0, estoqueBaixo = 0, estoqueCritico = 0;
            const categoriasCounts = {};
            
            if (apiStats.disponiveis !== undefined) {
                // Usar dados da API /api/estoque
                estoqueNormal = apiStats.disponiveis || 0;
                estoqueBaixo = apiStats.estoque_baixo || 0;
                estoqueCritico = apiStats.zerados || 0;
            } else {
                todosProdutos.forEach(p => {
                    const qtd = Number(p.estoque || 0);
                    const min = Number(p.estoque_minimo || 10);
                    if (qtd <= 0) estoqueCritico++;
                    else if (qtd <= min) estoqueBaixo++;
                    else estoqueNormal++;
                });
            }
            
            // Contar categorias (duplex, triplex, quadruplex, etc)
            if (apiStats.categorias) {
                Object.assign(categoriasCounts, apiStats.categorias);
            } else {
                todosProdutos.forEach(p => {
                    const cat = (p.categoria || detectarCategoria(p.nome) || 'OUTROS').toUpperCase();
                    categoriasCounts[cat] = (categoriasCounts[cat] || 0) + 1;
                });
            }

            const totalCategorias = apiStats.total_categorias || Object.keys(categoriasCounts).length;
            
            // Criar texto de detalhe das categorias
            const categoriasList = Object.entries(categoriasCounts)
                .sort((a, b) => b[1] - a[1]) // Ordenar por quantidade
                .slice(0, 3) // Top 3
                .map(([cat, qtd]) => `${cat}: ${qtd}`)
                .join(' | ');

            document.getElementById('stat-total').textContent = total;
            document.getElementById('stat-disponivel').textContent = estoqueNormal;
            document.getElementById('stat-baixo').textContent = estoqueBaixo;
            document.getElementById('stat-zerado').textContent = estoqueCritico;
            document.getElementById('stat-categorias').textContent = totalCategorias;
            
            // Mostrar detalhe das categorias
            const detailEl = document.getElementById('stat-categorias-detail');
            if (detailEl && categoriasList) {
                detailEl.textContent = categoriasList;
            }
        }

        // Filtrar produtos
        function filtrarProdutos() {
            const termo = document.getElementById('search-input').value.toLowerCase();
            const categoria = document.getElementById('filter-categoria').value;
            const status = document.getElementById('filter-status').value;

            produtosFiltrados = todosProdutos.filter(p => {
                // Filtro de busca - incluir SKU e código como no PCP
                const matchBusca = !termo || 
                    (p.codigo && p.codigo.toLowerCase().includes(termo)) ||
                    (p.nome && p.nome.toLowerCase().includes(termo)) ||
                    (p.descricao && p.descricao.toLowerCase().includes(termo)) ||
                    (p.sku && p.sku.toLowerCase().includes(termo)) ||
                    (p.gtin && p.gtin.toLowerCase().includes(termo));

                // Filtro de categoria
                const matchCategoria = !categoria || p.categoria === categoria;

                // Filtro de status - MESMA LÓGICA DO PCP
                const statusInfo = getStatusEstoque(p.estoque, p.estoque_minimo);
                let matchStatus = true;
                if (status === 'disponivel') matchStatus = statusInfo.status === 'normal';
                else if (status === 'baixo') matchStatus = statusInfo.status === 'baixo';
                else if (status === 'zerado') matchStatus = statusInfo.status === 'critico';

                return matchBusca && matchCategoria && matchStatus;
            });

            // Ordenar
            ordenarProdutos();
            
            // Reset página
            paginaAtual = 1;
            
            // Renderizar
            renderizarProdutos();
        }

        // Ordenar produtos
        function ordenar(campo) {
            if (ordenacaoAtual.campo === campo) {
                ordenacaoAtual.direcao = ordenacaoAtual.direcao === 'asc' ? 'desc' : 'asc';
            } else {
                ordenacaoAtual.campo = campo;
                ordenacaoAtual.direcao = 'asc';
            }
            ordenarProdutos();
            renderizarProdutos();
        }

        function ordenarProdutos() {
            const { campo, direcao } = ordenacaoAtual;
            produtosFiltrados.sort((a, b) => {
                let valA = a[campo];
                let valB = b[campo];
                
                if (typeof valA === 'string') {
                    valA = valA.toLowerCase();
                    valB = valB.toLowerCase();
                }
                
                if (valA < valB) return direcao === 'asc' ? -1 : 1;
                if (valA > valB) return direcao === 'asc' ? 1 : -1;
                return 0;
            });
        }

        // Renderizar produtos na tabela - FORMATO ALINHADO COM PCP
        function renderizarProdutos() {
            const tbody = document.getElementById('produtos-tbody');
            const emptyState = document.getElementById('empty-state');
            const tableWrapper = document.querySelector('.table-wrapper');

            if (produtosFiltrados.length === 0) {
                tbody.innerHTML = '';
                emptyState.style.display = 'block';
                tableWrapper.style.display = 'none';
                document.getElementById('items-showing').textContent = '0';
                document.getElementById('items-total').textContent = '0';
                return;
            }

            emptyState.style.display = 'none';
            tableWrapper.style.display = 'block';

            // PaginAção
            const inicio = (paginaAtual - 1) * itensPorPagina;
            const fim = inicio + itensPorPagina;
            const produtosPagina = produtosFiltrados.slice(inicio, fim);

            // Renderizar tabela - MESMO FORMATO DO PCP
            tbody.innerHTML = produtosPagina.map(p => {
                const statusInfo = getStatusEstoque(p.estoque, p.estoque_minimo);
                
