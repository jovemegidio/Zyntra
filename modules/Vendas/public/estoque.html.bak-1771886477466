        // Ver detalhes do produto - MODAL SAAS EMPRESARIAL
        async function verDetalhes(id) {
            const produto = todosProdutos.find(p => p.id === id);
            if (!produto) return;

            const statusInfo = getStatusEstoque(produto.estoque, produto.estoque_minimo);
            const statusClass = statusInfo.status === 'normal' ? 'disponivel' : statusInfo.status;
            const statusLabel = {
                'normal': 'Disponível para Venda',
                'baixo': 'Estoque Baixo - Atenção',
                'critico': 'Nível Crítico - Urgente'
            }[statusInfo.status];

            const statusIcon = {
                'normal': 'fa-check-circle',
                'baixo': 'fa-exclamation-triangle',
                'critico': 'fa-times-circle'
            }[statusInfo.status];

            // Calcular porcentagem do estoque (baseado em estoque mínimo * 5 como máximo referência)
            const estoqueMax = Math.max(produto.estoque_minimo * 5, produto.estoque, 100);
            const estoquePercent = Math.min((produto.estoque / estoqueMax) * 100, 100);
            
            // Formatar preço com R$
            const precoFormatado = produto.preco.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            // Formatar unidade (metros em vez de UN)
            const unidadeExibicao = formatarUnidade(produto.unidade);
            const unidadeAbrev = formatarUnidadeAbrev(produto.unidade);

            // Buscar movimentações recentes do produto e calcular lances disponíveis
            let movimentacoesHtml = '';
            let lancesDisponiveis = [];
            let lancesHtml = '';
            
            try {
                const movRes = await fetch('/api/pcp/produtos/' + id + '/movimentacoes?limit=100', { credentials: 'include' });
                if (movRes.ok) {
                    const movData = await movRes.json();
                    const todasMovimentacoes = movData.movimentacoes || movData || [];
                    
                    // Calcular lances disponíveis (FIFO - First In, First Out)
                    // Cada entrada cria um lance, cada saída consome dos lances mais antigos
                    const entradas = [];
                    const saidas = [];
                    
                    // Separar entradas e saídas (ordem cronológica)
                    todasMovimentacoes.slice().reverse().forEach(mov => {
                        const tipo = (mov.tipo || mov.tipo_movimento || '').toLowerCase();
                        const qtd = parseFloat(mov.quantidade || 0);
                        const data = new Date(mov.data || mov.data_movimento);
                        const obs = mov.observacao || '';
                        
                        if (tipo === 'entrada') {
                            // Verificar se a observação contém múltiplos lances
                            const matchLances = obs.match(/\[(\d+)\s*LANCES?:\s*([^\]]+)\]/i);
                            if (matchLances) {
                                // Múltiplos lances na mesma entrada
                                const valoresStr = matchLances[2].split('=')[0].trim();
                                const valores = valoresStr.split('+').map(v => parseFloat(v.replace(',', '.').trim()));
                                valores.forEach((val, idx) => {
                                    entradas.push({ quantidade: val, data: data, origem: 'Lance ' + (entradas.length + 1) });
                                });
                            } else {
                                // Entrada única
                                entradas.push({ quantidade: qtd, data: data, origem: 'Lance ' + (entradas.length + 1) });
                            }
                        } else if (tipo === 'saida') {
                            saidas.push({ quantidade: qtd, data: data });
                        }
                    });
                    
                    // Aplicar saídas aos lances (FIFO)
                    lancesDisponiveis = entradas.map(e => ({ ...e, restante: e.quantidade }));
                    
                    saidas.forEach(saida => {
                        let qtdADescontar = saida.quantidade;
                        for (let i = 0; i < lancesDisponiveis.length && qtdADescontar > 0; i++) {
                            const lance = lancesDisponiveis[i];
                            if (lance.restante > 0) {
                                const desconto = Math.min(lance.restante, qtdADescontar);
                                lance.restante -= desconto;
                                qtdADescontar -= desconto;
                            }
                        }
                    });
                    
                    // Filtrar apenas lances com saldo > 0
                    lancesDisponiveis = lancesDisponiveis.filter(l => l.restante > 0.01);
                    
                    // Gerar HTML dos lances disponíveis
                    if (lancesDisponiveis.length > 0) {
                        const totalLances = lancesDisponiveis.length;
                        const totalMetros = lancesDisponiveis.reduce((sum, l) => sum + l.restante, 0);
                        
