                            '<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px dashed #7dd3fc;">' +
                            '<div style="display: flex; align-items: center; gap: 8px;">' +
                            '<div style="width: 40px; height: 40px; background: linear-gradient(135deg, #0ea5e9, #0284c7); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700;">' + totalLances + '</div>' +
                            '<div><div style="font-size: 11px; color: #64748b; text-transform: uppercase;">Total de Lances</div>' +
                            '<div style="font-size: 14px; font-weight: 600; color: #0369a1;">' + totalLances + ' lance' + (totalLances > 1 ? 's' : '') + ' disponíve' + (totalLances > 1 ? 'is' : 'l') + '</div></div></div>' +
                            '<div style="text-align: right;"><div style="font-size: 11px; color: #64748b;">TOTAL</div>' +
                            '<div style="font-size: 18px; font-weight: 700; color: #0369a1;">' + totalMetros.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) + ' ' + unidadeAbrev + '</div></div></div>' +
                            '<div style="display: flex; flex-wrap: wrap; gap: 8px;">';
                        
                        lancesDisponiveis.forEach((lance, idx) => {
                            const dataStr = lance.data.toLocaleDateString('pt-BR');
                            lancesHtml += '<div style="flex: 1; min-width: 120px; background: white; border-radius: 8px; padding: 12px; border: 1px solid #e0f2fe; text-align: center;">' +
                                '<div style="font-size: 10px; color: #64748b; text-transform: uppercase; margin-bottom: 4px;">Lance ' + (idx + 1) + '</div>' +
                                '<div style="font-size: 20px; font-weight: 700; color: #0369a1;">' + lance.restante.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) + '</div>' +
                                '<div style="font-size: 11px; color: #94a3b8;">' + unidadeAbrev + '</div>' +
                                '<div style="font-size: 10px; color: #cbd5e1; margin-top: 4px;"><i class="fas fa-calendar-alt"></i> ' + dataStr + '</div></div>';
                        });
                        
                        lancesHtml += '</div></div></div>';
                    }
                    
                    // Gerar HTML das últimas movimentações (apenas as 5 mais recentes)
                    const movimentacoes = todasMovimentacoes.slice(0, 5);
                    if (movimentacoes.length > 0) {
                        movimentacoesHtml = movimentacoes.map(mov => {
                            const isEntrada = (mov.tipo || mov.tipo_movimento || '').toLowerCase() === 'entrada';
                            const data = new Date(mov.data || mov.data_movimento || mov.created_at);
                            const dataStr = data.toLocaleDateString('pt-BR') + ' ' + data.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
                            const bgColor = isEntrada ? '#dcfce7' : '#fee2e2';
                            const textColor = isEntrada ? '#166534' : '#991b1b';
                            const icon = isEntrada ? 'fa-arrow-down' : 'fa-arrow-up';
                            const sinal = isEntrada ? '+' : '-';
                            const tipoLabel = isEntrada ? 'ENTRADA' : 'SAÍDA';
                            const qtd = parseFloat(mov.quantidade || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 });
                            
                            // Verificar se tem detalhes de lances/recortes na observação
                            let detalhesLances = '';
                            if (mov.observacao && (mov.observacao.includes('LANCE') || mov.observacao.includes('RECORTE'))) {
                                const match = mov.observacao.match(/\[(\d+)\s*(LANCE|RECORTE)S?:\s*([^\]]+)\]/i);
                                if (match) {
                                    const numItens = match[1];
                                    const tipoItem = match[2].toLowerCase() === 'lance' ? 'lances' : 'recortes';
                                    const valores = match[3].split('=')[0].trim();
                                    const bgLance = isEntrada ? '#f0fdf4' : '#fef2f2';
                                    detalhesLances = '<div style="margin-top: 8px; padding: 8px 10px; background: ' + bgLance + '; border-radius: 6px; border-left: 3px solid ' + textColor + ';">' +
                                        '<div style="font-size: 10px; color: #64748b; text-transform: uppercase; font-weight: 600; margin-bottom: 4px;">' +
                                        '<i class="fas fa-ruler-combined" style="margin-right: 4px;"></i>' + numItens + ' ' + tipoItem + '</div>' +
                                        '<div style="font-size: 12px; color: #374151; font-family: monospace;">' + valores + '</div></div>';
                                }
                            }
                            
                            return '<div style="padding: 12px; border-bottom: 1px solid #f1f5f9; background: white;">' +
                                '<div style="display: flex; align-items: center; gap: 12px;">' +
                                '<div style="width: 36px; height: 36px; border-radius: 8px; background: ' + bgColor + '; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">' +
                                '<i class="fas ' + icon + '" style="color: ' + textColor + '; font-size: 14px;"></i></div>' +
                                '<div style="flex: 1; min-width: 0;">' +
                                '<div style="display: flex; justify-content: space-between; align-items: center;">' +
                                '<div><span style="font-weight: 700; color: ' + textColor + '; font-size: 15px;">' + sinal + qtd + ' ' + unidadeAbrev + '</span>' +
                                '<span style="background: ' + bgColor + '; color: ' + textColor + '; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; margin-left: 8px;">' + tipoLabel + '</span></div>' +
                                '<div style="font-size: 11px; color: #94a3b8;">' + dataStr + '</div></div>' +
                                detalhesLances + '</div></div></div>';
                        }).join('');
                    }
                }
            } catch (e) {
                console.log('Erro ao buscar movimentações:', e);
            }

            // Formatar data da última movimentação
            let ultimaMovimentacaoTexto = 'Sem movimentações';
            let ultimaMovimentacaoIcon = 'fa-clock';
            if (produto.ultima_movimentacao) {
                const dataMovimentacao = new Date(produto.ultima_movimentacao);
                ultimaMovimentacaoTexto = dataMovimentacao.toLocaleDateString('pt-BR', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
                ultimaMovimentacaoIcon = 'fa-history';
            }

            document.getElementById('modal-body').innerHTML = `
                <!-- Card do Produto - SAAS Premium -->
                <div class="modal-produto-card">
                    <div class="modal-produto-nome">${escapeHtml(produto.nome)}</div>
                    <div class="modal-produto-meta">
                        <span class="meta-item">
                            <i class="fas fa-hashtag"></i>
                            <strong>${escapeHtml(produto.codigo)}</strong>
                        </span>
                        <span class="separator">|||</span>
                        <span class="meta-item">
                            SKU: <strong>${escapeHtml(produto.sku || '-')}</strong>
                        </span>
                        <span class="separator">•</span>
                        <span class="meta-item">
                            <span class="categoria-badge ${produto.categoria.toLowerCase()}" style="font-size: 11px; padding: 3px 10px; border-radius: 6px;">${produto.categoria}</span>
                        </span>
                    </div>
                </div>

                <!-- Seção Estoque - Enterprise Design -->
                <div class="modal-section" style="background: #f8fafc;">
                    <div class="modal-section-title">
                        <i class="fas fa-boxes-stacked"></i>
                        Disponibilidade em Estoque
                    </div>
                    
                    <div class="estoque-card">
                        <div class="estoque-card-header">
                            <div class="estoque-card-icon ${statusClass}">
                                <i class="fas ${statusIcon}"></i>
                            </div>
                            <div class="estoque-card-info">
                                <div class="estoque-card-quantidade">
                                    ${produto.estoque.toFixed(2)}
                                    <small>${unidadeAbrev}</small>
                                </div>
                                <div class="estoque-card-status ${statusClass}">${statusLabel}</div>
                            </div>
                        </div>
                        
                        <div class="estoque-progress">
                            <div class="estoque-progress-bar">
                                <div class="estoque-progress-fill ${statusClass}" style="width: ${estoquePercent}%"></div>
                            </div>
                            <div class="estoque-progress-labels">
                                <span>Mín: ${produto.estoque_minimo} ${unidadeAbrev}</span>
                                <span>Atual: ${produto.estoque.toFixed(2)} ${unidadeAbrev}</span>
                            </div>
                        </div>
                        
                        <div class="modal-info-grid">
                            <div class="modal-info-item">
                                <label>Estoque Atual</label>
                                <span>${produto.estoque.toFixed(2)} ${unidadeAbrev}</span>
                            </div>
                            <div class="modal-info-item">
                                <label>Mínimo</label>
                                <span>${produto.estoque_minimo} ${unidadeAbrev}</span>
                            </div>
                            <div class="modal-info-item">
                                <label>Unidade</label>
                                <span>${unidadeExibicao}</span>
                            </div>
                            <div class="modal-info-item last-movement">
                                <label>Última Movimentação</label>
                                <span>
                                    <i class="fas ${ultimaMovimentacaoIcon}"></i>
                                    ${ultimaMovimentacaoTexto}
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Seção Lances Disponíveis -->
                ${lancesHtml}

                <!-- Seção Movimentações Recentes - Mostra Lances/Recortes -->
                ${movimentacoesHtml ? `
                <div class="modal-section">
                    <div class="modal-section-title">
                        <i class="fas fa-history"></i>
                        Últimas Movimentações (Lances/Recortes)
                    </div>
                    <div style="background: #f8fafc; border-radius: 10px; overflow: hidden; border: 1px solid #e2e8f0;">
                        ${movimentacoesHtml}
                    </div>
                </div>
                ` : ''}

                <!-- Seção Preço - Premium Design -->
                <div class="modal-section">
                    <div class="modal-section-title">
                        <i class="fas fa-money-bill-wave"></i>
                        Informações de Preço
                    </div>
                    <div class="preco-card">
                        <span class="preco-label">Preço de Venda</span>
                        <span class="preco-valor">R$ ${precoFormatado}</span>
                    </div>
                </div>

                <!-- Seção Informações Adicionais - Clean Design -->
                <div class="modal-section">
                    <div class="modal-section-title">
                        <i class="fas fa-clipboard-list"></i>
                        Informações Adicionais
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <label>GTIN/EAN</label>
                            <span>${escapeHtml(produto.gtin || 'não informado')}</span>
                        </div>
                        <div class="detail-item">
                            <label>NCM</label>
                            <span>${escapeHtml(produto.ncm || 'não informado')}</span>
                        </div>
                    </div>
                </div>

                <!-- Avisos - Minimal Design -->
                <div class="modal-avisos">
                    <div class="modal-aviso info">
                        <i class="fas fa-eye"></i>
                        <div>
                            <strong>Modo Conferência</strong><br>
                            <small>Esta página é somente leitura. Para editar estoque, acesse o módulo PCP.</small>
                        </div>
                    </div>
                    <div class="modal-aviso sync">
                        <i class="fas fa-sync-alt"></i>
                        <div>
                            <strong>Sincronização Automática</strong><br>
                            <small>Dados atualizados automaticamente a cada 30 segundos</small>
                        </div>
                    </div>
                </div>
            `;

            // Atualizar header do modal
            document.querySelector('#modal-detalhes .modal-header h2').innerHTML = `
                <i class="fas fa-cube"></i> Detalhes do Produto
            `;

            document.getElementById('modal-detalhes').classList.add('active');
        }

        function fecharModal() {
            document.getElementById('modal-detalhes').classList.remove('active');
        }

        // Fechar modal ao clicar fora
        document.getElementById('modal-detalhes').addEventListener('click', function(e) {
            if (e.target === this) fecharModal();
        });

        // Escape HTML para prevenir XSS
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Mostrar erro
        function mostrarErro(msg) {
            alert(msg);
        }

        // Atalhos de teclado
        document.addEventListener('keydown', function(e) {
            // ESC fecha modal
            if (e.key === 'Escape') fecharModal();
            // Ctrl+F foca na busca
            if (e.ctrlKey && e.key === 'f') {
                e.preventDefault();
                document.getElementById('search-input').focus();
            }
            // F5 atualiza dados
            if (e.key === 'F5') {
                e.preventDefault();
                carregarProdutos();
            }
        });

        // Limpar intervalo ao sair da página
        window.addEventListener('beforeunload', () => {
            if (autoRefreshInterval) clearInterval(autoRefreshInterval);
        });

        // Pausar auto-refresh quando a página não está visível
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                if (autoRefreshInterval) clearInterval(autoRefreshInterval);
            } else {
                iniciarAutoRefresh();
                carregarProdutos(true); // Silent refresh ao voltar
            }
        });
        
        // Toggle Sidebar Mobile
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobileOverlay');
            sidebar.classList.toggle('open');
            overlay.classList.toggle('active');
        }
    </script>
    <script src="/js/popup-confirmacao.js"></script>
    <script src="/js/auth-unified.js?v=20260131"></script>
    <script src="/js/mobile-auto-enhance.js?v=20260202" defer></script>
    <!-- Chat Widget BOB AI - DESATIVADO -->
    <!-- <script src="/chat/widget.js?v=20260218" defer></script> -->
    <script src="/js/user-dropdown.js?v=20260223" defer></script>

<script src="/_shared/accessibility-widget.js"></script>
</body>
</html>





